<root>

    <TreeNodesModel>
        <Action ID="OpenDoor"/>
        <Action ID="PickLock"/>
        <Action ID="SmashDoor"/>
    </TreeNodesModel>

    <BehaviorTree ID="DoorClosed">
        <Fallback>
            <Sequence>
                <OpenDoor/>
            </Sequence>
            <Sequence>
                <!-- TODO: Instead call the decode subtree and UseDoorCode node here-->
                <RetryUntilSuccessful num_attempts="5">
                    <PickLock/>
                </RetryUntilSuccessful>
            </Sequence>
            <Sequence>
                <SmashDoor/>
            </Sequence>
        </Fallback>
    </BehaviorTree>
</root>
