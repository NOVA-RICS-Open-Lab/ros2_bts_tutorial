<root main_tree_to_execute="MainTree">
    <!-- TODO include path to password decode subtree -->
    <include path="./bt_tutorial_05_subtree_doorclosed.xml"/>

    <TreeNodesModel>
        <Action ID="IsDoorClosed"/>
        <Action ID="PassThroughDoor"/>
        <SubTree ID="DoorClosed"/>
        <Action ID="LogResult"/>
    </TreeNodesModel>
    
    <BehaviorTree ID="MainTree">
        <Sequence>
            <Fallback>
                <Inverter>
                    <IsDoorClosed/>
                </Inverter>
                <SubTree ID="DoorClosed"/>
            </Fallback>
            <PassThroughDoor/>
            <LogResult/>
        </Sequence>
    </BehaviorTree>

</root>
